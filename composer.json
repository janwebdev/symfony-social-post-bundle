{
  "name": "janwebdev/symfony-social-post-bundle",
  "type": "symfony-bundle",
  "description": "Modern Symfony bundle for posting to social networks (Twitter, Facebook, LinkedIn, Telegram, Instagram, Discord, WhatsApp) with async support",
  "keywords": [
    "symfony",
    "bundle",
    "facebook",
    "twitter",
    "linkedin",
    "telegram",
    "instagram",
    "discord",
    "whatsapp",
    "social network",
    "social media",
    "async",
    "messenger",
    "php8.4",
    "symfony7"
  ],
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Martin Georgiev",
      "email": "martin.georgiev@gmail.com"
    },
    {
      "name": "Yan Rogozinsky",
      "email": "janwebdev@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Janwebdev\\SocialPostBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Janwebdev\\SocialPostBundle\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.4",
    "symfony/framework-bundle": "^7.4",
    "symfony/http-client": "^7.4",
    "symfony/event-dispatcher": "^7.4",
    "symfony/messenger": "^7.4",
    "symfony/config": "^7.4",
    "symfony/dependency-injection": "^7.4",
    "symfony/yaml": "^7.4",
    "psr/http-client": "^1.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "php-coveralls/php-coveralls": "^2.7",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^11.0",
    "symfony/phpunit-bridge": "^7.4",
    "symfony/var-dumper": "^7.4"
  },
  "scripts": {
    "check-code-style": [
      "php-cs-fixer fix --config='./ci/php-cs-fixer/config.php' --show-progress=none --dry-run --no-interaction --diff -v"
    ],
    "fix-code-style": [
      "php-cs-fixer fix --config='./ci/php-cs-fixer/config.php' --show-progress=none --no-interaction --diff -v"
    ],
    "run-static-analysis": [
      "phpstan analyse --configuration='./ci/phpstan/config.neon' --no-progress --level=9 src/ tests/"
    ],
    "run-tests": [
      "phpunit --configuration='./ci/phpunit/config.xml'"
    ],
    "run-tests-with-clover": [
      "phpunit --configuration='./ci/phpunit/config.xml' --coverage-clover './build/logs/clover.xml'"
    ]
  },
  "config": {
    "bin-dir": "bin",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "prefer-stable": true
}
